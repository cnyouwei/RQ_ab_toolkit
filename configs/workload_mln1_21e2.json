{
  "simulation": {
    "warmup_time": 100000.0,
    "sample_time": 1000000.0,
    "replications": 100,
    "threads": 0,
    "seed": 123456789,
    "normalize_service_mean_to_one": true
  },
  "model": {
    "name": "M/LN(1,2)/1+E_2 example",
    "alias": "mln1_21e2",
    "arrival": {
      "distribution": {
        "family": "exponential",
        "params": {
          "rate": 1.0
        }
      }
    },
    "service": {
      "distribution": {
        "family": "lognormal",
        "params": {
          "mean": 1.0,
          "scv": 2.0
        }
      }
    },
    "patience": {
      "distribution": {
        "family": "erlang_k",
        "params": {
          "k": 2,
          "rate": 2.0
        }
      }
    }
  }
}
